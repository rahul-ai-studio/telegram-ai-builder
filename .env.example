# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here      # only this chat_id can use the bot
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Security (strongly recommended) ───────────────────────────────────────────
# If set, the bot requires /auth <pin> before it will respond to any command.
# The PIN message is auto-deleted so it never persists in Telegram chat history.
# This protects you even if your Telegram account is compromised.
BOT_SECRET_PIN=change_this_to_a_strong_passphrase

# How long an authenticated session stays active (default: 24 hours).
# After expiry the bot will prompt for /auth again.
SESSION_TTL_HOURS=24

# ── Optional ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=~/ai-builder-output
TIMEZONE=UTC
